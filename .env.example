# Copy this file to server/npc-brain/.env and fill in your real keys.
# Do not commit the real .env file.

# LangSmith tracing / deploy CLI
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=3KLife-npc-brain-local
LANGSMITH_DEPLOYMENT_NAME=3klife-npc-brain-external-test

# Shared API key for Studio / deployment callers.
# Callers send this via X-API-Key or Authorization: Bearer <key>.
NPC_BRAIN_DEPLOY_API_KEY=
NPC_BRAIN_DEPLOY_IDENTITY=npc-brain-external-tester

# LLM providers
GOOGLE_API_KEY=
NPC_LLM_PROVIDER_ORDER=gemini,deterministic
NPC_LLM_MODEL_GEMINI=gemini-2.5-pro
NPC_LLM_TIMEOUT_MS=6000

# Vector retrieval / embedding routing
# Short term: keep Pinecone first for quick cloud integration.
# Long term: keep Qdrant ready so the service can migrate without renaming logical namespaces.
NPC_VECTOR_PROVIDER_ORDER=pinecone,qdrant,sqlite_vec
NPC_VECTOR_DEFAULT_PROVIDER=pinecone
NPC_VECTOR_DIMENSION=1024
NPC_EMBEDDING_PROVIDER=sentence_transformers
NPC_EMBEDDING_MODEL=BAAI/bge-m3
NPC_VECTOR_NAMESPACE_FACTS=romance_facts_v1
NPC_VECTOR_NAMESPACE_KEYWORDS=general_keywords_v1
NPC_VECTOR_NAMESPACE_PERSONA=general_persona_v2

# Pinecone (quick cloud lane)
PINECONE_API_KEY=
NPC_PINECONE_INDEX=sanguo-npc-brain-dev
NPC_PINECONE_CLOUD=aws
NPC_PINECONE_REGION=us-east-1
NPC_PINECONE_METRIC=cosine

# Qdrant (long-term self-hosted lane)
NPC_QDRANT_URL=http://127.0.0.1:6333
NPC_QDRANT_API_KEY=
NPC_QDRANT_COLLECTION_FACTS=romance_facts_v1
NPC_QDRANT_COLLECTION_KEYWORDS=general_keywords_v1
NPC_QDRANT_COLLECTION_PERSONA=general_persona_v2

# Local degrade / high-frequency persona cache
NPC_SQLITE_VEC_DB_PATH=save/npc_memory.db
