{
  "id": "Policy_RuntimeReadinessMatrix_P1",
  "description": "Externalized deterministic smoke defaults for build_runtime_readiness_matrix.py. Values are copied from Phase 11 baseline.",
  "defaultGeneralIds": [
    "cao-cao",
    "guan-yu",
    "liu-bei",
    "lu-bu",
    "sun-quan",
    "wei-yan",
    "yuan-shao",
    "zhang-fei",
