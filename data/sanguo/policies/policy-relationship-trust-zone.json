{
  "id": "Policy_RelationshipTrustZone_P1",
  "schemaVersion": "relationship-trust-zone-policy.v0.1",
  "description": "Builds accumulating/review/stable/skill-reviewed/human-locked trust zones for relationship and faction timeline claims. Human-locked rows are relationship-alias-like mirrors, not handwritten canon.",
  "inputs": {
    "relationshipClaimsPath": "artifacts/data-pipeline/sanguo-rag/extracted/relationship-claim-graph/relationship-claims.jsonl",
    "stableBootstrapPath": "artifacts/data-pipeline/sanguo-rag/extracted/stable-knowledge-bootstrap/stable-knowledge-bootstrap.json",
    "formalMentionMapPath": "artifacts/data-pipeline/sanguo-rag/extracted/alias-dictionary/formal-mention-map.json",
    "humanReviewDecisionsPath": "artifacts/data-pipeline/sanguo-rag/extracted/baihua-bootstrap/wave-001-max1200/top50-strict-human-decisions.approved-status.json",
    "previousSkipIndexPath": "artifacts/data-pipeline/sanguo-rag/extracted/relationship-trust-zone/relationship-trust-zone.skip-index.json",
    "skillReviewEvidencePath": "artifacts/data-pipeline/sanguo-rag/extracted/relationship-trust-zone/relationship-trust-zone.skill-review-evidence.jsonl",
    "semanticReviewEvidencePath": "artifacts/data-pipeline/sanguo-rag/extracted/relationship-trust-zone/relationship-trust-zone.semantic-review-evidence.jsonl",
    "secondarySemanticReviewEvidencePath": "artifacts/data-pipeline/sanguo-rag/extracted/relationship-trust-zone/relationship-trust-zone.semantic-review-secondary-evidence.jsonl",
    "generalAliasRecordsPath": "artifacts/data-pipeline/sanguo-rag/extracted/alias-dictionary/general-alias-records.json"
  },
  "outputs": {
    "outputRoot": "artifacts/data-pipeline/sanguo-rag/extracted/relationship-trust-zone",
    "stableFileName": "relationship-trust-zone.stable.jsonl",
    "skillReviewedFileName": "relationship-trust-zone.skill-reviewed.jsonl",
    "humanLockedFileName": "relationship-trust-zone.human-locked.jsonl",
    "humanRejectedFileName": "relationship-trust-zone.human-rejected.jsonl",
    "humanRemovedFileName": "relationship-trust-zone.human-removed.jsonl",
    "reviewFileName": "relationship-trust-zone.review.jsonl",
    "accumulatingFileName": "relationship-trust-zone.accumulating.jsonl",
    "conflictFileName": "relationship-trust-zone.conflicts.jsonl",
    "skipIndexFileName": "relationship-trust-zone.skip-index.json",
    "rulerEligibilitySnapshotFileName": "relationship-trust-zone.ruler-eligibility.snapshot.json",
    "rulerEligibilityReviewMarkdownFileName": "relationship-trust-zone.ruler-eligibility.review.zh-TW.md",
    "humanReviewMarkdownFileName": "relationship-trust-zone-human-review.md",
    "humanDecisionTemplateFileName": "relationship-trust-zone.human-decisions.template.json",
    "factCheckFileName": "relationship-trust-zone.fact-check.jsonl",
    "factCheckMarkdownFileName": "relationship-trust-zone-fact-check.md",
    "relationshipReviewTable95PlusFileName": "relationship-trust-zone-review-95plus.relationships.md",
    "factionReviewTable95PlusFileName": "relationship-trust-zone-review-95plus.factions.md",
    "relationshipReviewTable95PlusJsonlFileName": "relationship-trust-zone-review-95plus.relationships.jsonl",
    "factionReviewTable95PlusJsonlFileName": "relationship-trust-zone-review-95plus.factions.jsonl",
    "summaryFileName": "relationship-trust-zone-summary.json"
  },
  "zones": {
    "stableMinScore": 90.0,
    "reviewMinScore": 80.0,
    "skillReviewedScore": 95.0,
    "humanReviewedScore": 100.0,
    "humanRejectedScore": 0.0,
    "fixedAliasMinScore": 100.0,
    "noRecomputeMinScore": 90.0
  },
  "stageNames": {
    "accumulating": "accumulating",
    "review": "review",
    "stable": "stable-90",
    "skillReviewed": "skill-reviewed-95",
    "humanLocked": "human-locked-100",
    "humanRejected": "human-rejected-0",
    "humanRemoved": "human-removed-from-index"
  },
  "keyModel": {
    "description": "Trust is accumulated by relationship pair key, not by a single person's global faction/ruler slot.",
    "directedKeyFields": ["dimension", "relationshipType", "fromId", "toId"],
    "bidirectionalKeyFields": ["dimension", "relationshipType", "pairId"],
    "scopeFieldsAreMetadataOnly": true,
    "sameSubjectDifferentControllerAllowed": true,
    "example": "ma-teng -> ma-chao and liu-bei -> ma-chao are independent trust keys."
  },
  "scoreModel": {
    "maxScore": 100.0,
    "claimGradeBaseScores": {
      "A-history-cross-source": 94.0,
      "A-history": 92.0,
      "A-romance": 90.0,
      "A-baseline": 92.0,
      "B-history": 78.0,
      "B-history-profile-baseline": 72.0,
      "B-romance": 76.0,
      "B-secondary": 62.0
    },
    "edgeConfidenceWeight": 4.0,
    "edgeStrengthWeight": 3.0,
    "booleanFieldBonuses": {
      "directPairSignal": 1.5,
      "pairRelationSignal": 2.0
    },
    "quoteLocatorHashBonus": 2.0,
    "confidenceSignalBonuses": {
      "cross-source": 1.5,
      "internal-external": 1.5,
      "quote+locator+hash": 1.0,
      "anchor-passage-pair-cue": 1.0,
      "baihua-translation-anchor": 0.5,
      "strict-ruler-subject": 4.0,
      "faction-timeline": 4.0
    },
    "promotionTraceBonuses": {
      "quote-locator-hash": 1.0,
      "cross-family-history": 2.0,
      "pair-relation-cue": 1.0,
      "local-curated-stable-baseline": 4.0
    },
    "additionalEvidenceBonus": 1.0,
    "additionalEvidenceCap": 5,
    "crossSourceFamilyBonus": 2.0,
    "maxSupportingItems": 10,
    "semanticInferencePolicy": {
      "principle": "Deterministic relationship extraction narrows candidate windows and preserves full source sentences; it must not be treated as semantic truth for hard relationships.",
      "deterministicOutputsAre": ["candidateRelationshipType", "pairRelationCue", "sourceQuote", "locator", "textHash"],
      "requiresReviewerForStableTruth": ["parent_child", "adoptive_parent_child", "spouse", "sibling", "sworn_sibling", "ruler_subject"],
      "reviewerPromotionSources": ["skill-review-evidence", "human-review", "stable-bootstrap-seed"],
      "canonicalWrites": false
    },
    "scoreCaps": [
      {
        "description": "Hard pair relationships may enter a narrowed review queue, but deterministic pair cues are not semantic truth and cannot reach stable/95 without reviewer evidence.",
        "relationshipTypes": ["parent_child", "adoptive_parent_child", "spouse", "sibling", "sworn_sibling", "ruler_subject"],
        "unlessSupportingEvidenceRequiresAny": [
          {"field": "sourceLayer", "equals": "stable-bootstrap-seed"},
          {"field": "promotionTrace", "contains": "local-curated-stable-baseline"},
          {"field": "humanReviewStatus", "contains": "human-approved"},
          {"field": "reviewStatus", "contains": "accepted-by-human"}
        ],
        "maxScore": 89.0,
        "stableBlocker": "semantic-review-required-before-stable"
      }
    ],
    "humanReviewStatusFields": ["humanReviewStatus", "reviewStatus"],
    "humanApprovedStatuses": ["human-approved", "reviewed-accepted", "accepted-by-human"]
  },
  "semanticReview": {
    "enabled": true,
    "description": "Local or remote sentence-level semantic extraction before skill review. The model reads the preserved source sentence first, extracts explicit relationship facts, then maps them back to candidate trust keys. Cached by sentence hash and remains proposal-only.",
    "reviewMode": "sentence-relation-extraction",
    "promptVersion": "relationship-semantic-review.v5-alias-consensus-grounding",
    "reviewerProvider": "ollama",
    "reviewerPreset": "quality",
    "apiUrl": null,
    "model": "deepseek-r1:7b",
    "timeoutMs": 90000,
    "numCtx": 4096,
    "numPredict": 900,
    "candidateStages": ["review", "stable-90"],
    "cacheFileName": "relationship-trust-zone.semantic-review-cache.jsonl",
    "queueFileName": "relationship-trust-zone.semantic-review-queue.jsonl",
    "evidenceFileName": "relationship-trust-zone.semantic-review-evidence.jsonl",
    "summaryFileName": "relationship-trust-zone.semantic-review-summary.json",
    "maxCandidatesPerSentence": 6,
    "supportedVerdicts": ["supported"],
    "minSupportedConfidence": 0.78,
    "minSupportedTrustScore": 80.0,
    "highTrustScore": 90.0,
    "skillReviewPreferredMinTrustScore": 90.0,
    "requireStrictPairCheck": true,
    "scoreScale": "0-100",
    "scoreSemantics": "semanticTrustScore is sentence-level LLM confidence that a preserved source sentence supports the pair-key relationship. It may guide ranking and cache reuse, but it does not directly mutate the final trust-zone score.",
    "cacheKeyFields": ["promptVersion", "normalizedSourceSentence"],
    "structureGate": {
      "enabled": true,
      "defaultWindowLimit": 24,
      "maxWindowLimit": 64,
      "relationshipTypeWindowLimits": {
        "ruler_subject": 24,
        "spouse": 18,
        "parent_child": 16,
        "adoptive_parent_child": 18,
        "sibling": 16,
        "sworn_sibling": 18,
        "faction_membership": 18
      },
      "sourceLayerWindowLimits": {
        "baihua-anchor-passages": 44
      },
      "confidenceSignalWindowBonuses": {
        "anchor-passage-pair-cue": 4,
        "baihua-translation-anchor": 8,
        "strict-ruler-subject": 4
      },
      "reasonLabels": {
        "pairCueWindowTooWide": "pair-cue-window-too-wide"
      },
      "canonicalWrites": false
    },
    "pageShapeTelemetry": {
      "enabled": true,
      "excludeSuppressedFromQueue": true,
      "structuralThresholds": {
        "shortSegmentMaxLength": 12,
        "digitRatioWarn": 0.12,
        "digitRatioStrong": 0.18,
        "punctuationRatioWarn": 0.08,
        "punctuationRatioStrong": 0.14,
        "fullwidthParenWarnCount": 4,
        "fullwidthParenStrongCount": 8,
        "yearLikeWarnCount": 2,
        "yearLikeStrongCount": 4,
        "shortSegmentWarnCount": 5,
        "shortSegmentStrongCount": 8,
        "numberTokenWarnCount": 4,
        "numberTokenStrongCount": 8
      },
      "penalties": {
        "digitRatioWarn": 1.5,
        "digitRatioStrong": 3.0,
        "punctuationRatioWarn": 1.0,
        "punctuationRatioStrong": 2.0,
        "fullwidthParenWarn": 2.0,
        "fullwidthParenStrong": 4.0,
        "yearLikeWarn": 2.5,
        "yearLikeStrong": 5.0,
        "shortSegmentWarn": 2.5,
        "shortSegmentStrong": 5.0,
        "numberTokenWarn": 2.0,
        "numberTokenStrong": 4.0,
        "negativeKeywordHit": 2.0,
        "narrativeKeywordHitBoost": 1.5,
        "pairCueKeywordHitBoost": 2.5
      },
      "keywordsZhTw": {
        "negativePageType": ["統計", "對比", "總計", "生卒", "生年", "卒年", "資料", "數據", "電子辭典", "年表", "一覽", "列表", "排行", "合作次數", "勝率"],
        "narrativePositive": ["率軍", "引兵", "攻", "守", "娶", "嫁", "之子", "兒子", "其子", "其父", "其母", "兄弟", "姊妹", "從之", "歸附", "歸降", "麾下"],
        "pairCuePositive": ["命", "令", "遣", "使", "拜為", "授為", "封為", "以為", "為將", "為相", "為太守", "為都督"]
      },
      "suppression": {
        "minPenaltyScore": 8.0,
        "minStructuralTriggerCount": 2,
        "maxNarrativeKeywordHits": 0,
        "maxPairCueKeywordHits": 0
      },
      "canonicalWrites": false
    },
    "queueRanking": {
      "sortFields": [
        {"field": "pageShapePriorityScore", "direction": "desc"},
        {"field": "sourcePreviewPriorityMax", "direction": "desc"},
        {"field": "focusQueuePriority", "direction": "desc"},
        {"field": "candidateMaxScoreBeforeSemanticReview", "direction": "desc"},
        {"field": "candidateCount", "direction": "asc"},
        {"field": "sentenceQualityScore", "direction": "desc"},
        {"field": "semanticReviewUnitId", "direction": "asc"}
      ],
      "canonicalWrites": false
    },
    "consensus": {
      "enabled": true,
      "supportedStatuses": ["preferred-for-skill-review", "supported-for-review"],
      "preferredMinTrustScore": 90.0,
      "supportedMinTrustScore": 80.0,
      "canonicalWrites": false
    },
    "secondaryRunner": {
      "reviewerProvider": "ollama",
      "reviewerPreset": "balanced",
      "apiUrl": null,
      "model": "qwen2.5:7b",
      "timeoutMs": 90000,
      "numCtx": 4096,
      "numPredict": 900,
      "cacheFileName": "relationship-trust-zone.semantic-review-secondary-cache.jsonl",
      "queueFileName": "relationship-trust-zone.semantic-review-secondary-queue.jsonl",
      "evidenceFileName": "relationship-trust-zone.semantic-review-secondary-evidence.jsonl",
      "summaryFileName": "relationship-trust-zone.semantic-review-secondary-summary.json"
    },
    "codexSkillBridge": {
      "enabled": true,
      "description": "Temporary Codex-side sentence semantic reviewer used when local models are unavailable or too weak. It exports review packets and imports reviewed cache rows into the same semantic evidence contract.",
      "skillPath": "integrations/codex-skills/sanguo-relationship-semantic-review/SKILL.md",
      "bridgeScript": "pipelines/sanguo-rag/run_codex_relationship_semantic_review_bridge.py",
      "packetFileName": "codex-relationship-semantic-review-packet.json",
      "packetMarkdownFileName": "codex-relationship-semantic-review-packet.md",
      "reviewedCacheFileName": "codex-relationship-semantic-reviewed-cache.jsonl",
      "reviewerProvider": "codex-skill",
      "canonicalWrites": false,
      "replacementPlan": "Replace with an ollama-compatible stronger local or trusted remote model by changing semanticReview reviewerProvider/apiUrl/model; keep output evidence contract unchanged."
    },
    "canonicalWrites": false,
    "systemPromptZhTw": "你是三國人物關係的句級語意審查員。只根據輸入的 sourceSentence 與候選 relationships 判斷該句是否支持每一個 pair-key 關係。deterministic extractor 只負責縮小候選範圍，不代表語意為真；不可只看關鍵字。如果句子只表示派遣、命令、推薦、攻打、見面、稱呼，不能直接推成君臣、親子、夫妻或結義。如果方向不明、主詞不明、年代不明或只能推測，請給 uncertain 或 not_enough_context。輸出 JSON：{\"relationships\":[{\"trustKey\":\"...\",\"verdict\":\"supported|contradicted|uncertain|not_enough_context\",\"semanticTrustScore\":0到100,\"confidence\":0到1,\"evidenceSentence\":\"原文句\",\"rationaleZhTw\":\"繁體中文理由\"}]}。semanticTrustScore 是句級語意信任分數，不是最終關係信任區分數；這一關不得宣告 canonicalWrites，也不得把候選直接升成白名單。"
  },
  "focusQueue": {
    "enabled": true,
    "description": "When focus general ids are supplied, only unresolved gap slots in the configured relationship order should enter semantic or skill review.",
    "relationshipTypePriority": ["ruler_subject", "spouse", "parent_child", "sibling"],
    "resolvedStages": ["skill-reviewed-95", "human-locked-100", "human-rejected-0"],
    "slotCaps": {
      "ruler_subject": 2,
      "spouse": 1,
      "parent_child": 2,
      "sibling": 2
    },
    "slotRoleFields": {
      "ruler_subject": ["toId", "subjectId"],
      "spouse": ["fromId", "toId"],
      "parent_child": ["fromId", "toId", "subjectId", "controllerId"],
      "sibling": ["fromId", "toId"]
    },
    "priorityWeights": {
      "relationshipTypeWeight": 1000.0,
      "missingSlotWeight": 100.0,
      "rowScoreWeight": 1.0
    },
    "canonicalWrites": false
  },
  "skillReview": {
    "enabled": true,
    "mode": "claim-sentence-fact-check",
    "applicableDimensions": ["relationship"],
    "candidateStages": ["stable-90"],
    "minScore": 90.0,
    "promotedScore": 95.0,
    "minEvidenceCount": 1,
    "requireNoStableBlockers": true,
    "requiredRecordFields": ["trustKey", "relationshipType", "subjectId", "controllerId"],
    "requiredSupportingEvidenceAnyFields": [
      ["claimId", "sourceId", "sourceFamily", "sourceLayer"]
    ],
    "typeEvidenceRequirements": {
      "enemy_rival": {
        "supportingEvidenceRequiresAny": [
          {"field": "pairRelationSignal", "equals": true},
          {"field": "promotionTrace", "contains": "pair-relation-cue"}
        ]
      },
      "parent_child": {
        "supportingEvidenceRequiresAny": [
          {"field": "pairRelationSignal", "equals": true},
          {"field": "sourceLayer", "equals": "stable-bootstrap-seed"},
          {"field": "confidenceSignals", "contains": "anchor-passage-pair-cue"},
          {"field": "promotionTrace", "contains": "local-curated-stable-baseline"},
          {"field": "promotionTrace", "contains": "pair-relation-cue"}
        ]
      },
      "adoptive_parent_child": {
        "supportingEvidenceRequiresAny": [
          {"field": "pairRelationSignal", "equals": true},
          {"field": "sourceLayer", "equals": "stable-bootstrap-seed"},
          {"field": "confidenceSignals", "contains": "anchor-passage-pair-cue"},
          {"field": "promotionTrace", "contains": "local-curated-stable-baseline"},
          {"field": "promotionTrace", "contains": "pair-relation-cue"}
        ]
      },
      "spouse": {
        "supportingEvidenceRequiresAny": [
          {"field": "pairRelationSignal", "equals": true},
          {"field": "sourceLayer", "equals": "stable-bootstrap-seed"},
          {"field": "confidenceSignals", "contains": "anchor-passage-pair-cue"},
          {"field": "promotionTrace", "contains": "local-curated-stable-baseline"},
          {"field": "promotionTrace", "contains": "pair-relation-cue"}
        ]
      },
      "sibling": {
        "supportingEvidenceRequiresAny": [
          {"field": "pairRelationSignal", "equals": true},
          {"field": "sourceLayer", "equals": "stable-bootstrap-seed"},
          {"field": "confidenceSignals", "contains": "anchor-passage-pair-cue"},
          {"field": "promotionTrace", "contains": "local-curated-stable-baseline"},
          {"field": "promotionTrace", "contains": "pair-relation-cue"}
        ]
      },
      "sworn_sibling": {
        "supportingEvidenceRequiresAny": [
          {"field": "pairRelationSignal", "equals": true},
          {"field": "sourceLayer", "equals": "stable-bootstrap-seed"},
          {"field": "confidenceSignals", "contains": "anchor-passage-pair-cue"},
          {"field": "promotionTrace", "contains": "local-curated-stable-baseline"},
          {"field": "promotionTrace", "contains": "pair-relation-cue"}
        ]
      },
      "ruler_subject": {
        "supportingEvidenceRequiresAny": [
          {"field": "confidenceSignals", "contains": "strict-ruler-subject"},
          {"field": "confidenceSignals", "contains": "faction-timeline"},
          {"field": "sourceClaimScopes", "contains": "faction_timeline"},
          {"field": "sourceLayer", "equals": "stable-bootstrap-seed"}
        ]
      }
    },
    "factCheck": {
      "enabled": true,
      "claimSentenceLanguage": "zh-TW",
      "verifiedVerdict": "verified",
      "unverifiedVerdict": "unverified-needs-source-query",
      "minEligibleEvidenceItems": 1,
      "minDistinctSourceFamilies": 1,
      "allowTrustedSingleSource": true,
      "requireExternalLookupFor95": true,
      "externalVerifiedVerdicts": ["verified", "supported", "approved", "pass"],
      "evidenceBasisMaxItems": 5,
      "evidenceBasisQuoteMaxChars": 220,
      "trustedSingleSourceLayers": ["stable-bootstrap-seed"],
      "eligibleEvidenceRequiresAny": [
        {"field": "sourceLayer", "equals": "stable-bootstrap-seed"},
        {"field": "pairRelationSignal", "equals": true},
        {"field": "confidenceSignals", "contains": "anchor-passage-pair-cue"},
        {"field": "confidenceSignals", "contains": "strict-ruler-subject"},
        {"field": "confidenceSignals", "contains": "faction-timeline"},
        {"field": "sourceClaimScopes", "contains": "faction_timeline"},
        {"field": "promotionTrace", "contains": "local-curated-stable-baseline"},
        {"field": "promotionTrace", "contains": "pair-relation-cue"}
      ],
      "queryTargets": ["approved-external-relationship-sites", "anchor-corpus", "stable-bootstrap", "relationship-claim-graph"],
      "queryTemplateZhTw": "{fromName} {toName} {relationshipLabel} 關係 證據",
      "negativeQueryTemplateZhTw": "{fromName} 不是 {toName} {relationshipLabel} 證據",
      "sourceQuotePreviewMaxChars": 180,
      "sourceQuotePreviewMaxItems": 3,
      "sourceQuotePreviewOrdering": {
        "enabled": true,
        "sourceLayerBonuses": {
          "baihua-anchor-passages": 120,
          "stable-bootstrap-seed": 80
        },
        "confidenceSignalBonuses": {
          "baihua-translation-anchor": 80,
          "anchor-passage-pair-cue": 40,
          "strict-ruler-subject": 30,
          "faction-timeline": 30
        },
        "booleanFieldBonuses": {
          "pairRelationSignal": 20,
          "directPairSignal": 12
        },
        "quoteLengthCap": 220,
        "canonicalWrites": false
      },
      "reviewInstructionsZhTw": [
        "技能查證必須審查一個明確命題句，而不是只看欄位是否完整。",
        "技能查證必須同時看原文句或證據摘錄與命題句，判斷原文是否真的支持該兩人關係鍵。",
        "如果沒有實際外部查證紀錄，不能升 95 分，只能留在待複核或後段查證隊列。",
        "如果查到反證或原文方向相反，必須留待人工打叉或進黑名單。"
      ]
    },
    "passStatus": "skill-reviewed",
    "failStatus": "skill-review-needs-human",
    "failStage": "review",
    "passVerdict": "pass",
    "failVerdict": "needs-human-review",
    "reviewerId": "relationship-trust-zone-skill-review",
    "humanReviewRequiredAfterPass": true
  },
  "skillReviewRounds": {
    "enabled": true,
    "description": "Builds proposal-only Traditional Chinese review rounds from relationship trust-zone fact-check rows. These files are queues for skill/human verification and must not promote records by themselves.",
    "roundCountDefault": 3,
    "itemsPerRoundDefault": 12,
    "selectionMode": "balanced-by-relationship-type",
    "maxPerRelationshipTypePerRoundDefault": 6,
    "candidateStages": ["review", "stable-90"],
    "preferRelationshipTypes": ["ruler_subject", "faction_membership", "parent_child", "adoptive_parent_child", "spouse", "sworn_sibling", "sibling"],
    "excludeRelationshipTypes": [],
    "reviewQueueFileNameTemplate": "relationship-trust-zone-skill-review-round-{roundNo}.jsonl",
    "reviewMarkdownFileNameTemplate": "relationship-trust-zone-skill-review-round-{roundNo}.md",
    "aggregateJsonlFileName": "relationship-trust-zone-skill-review-human-review.jsonl",
    "aggregateMarkdownFileName": "relationship-trust-zone-skill-review-human-review.md",
    "summaryFileName": "relationship-trust-zone-skill-review-rounds-summary.json",
    "maxExistingEvidenceItems": 3,
    "maxQueryItems": 4,
    "maxQuoteChars": 220,
    "canonicalWrites": false,
    "semanticPriority": {
      "enabled": true,
      "preferredMinTrustScore": 90.0,
      "supportedMinTrustScore": 80.0,
      "residualMaxTrustScore": 60.0,
      "blacklistCandidateVerdicts": ["contradicted"],
      "residualVerdicts": ["not_enough_context", "uncertain"],
      "residualFileName": "relationship-trust-zone-semantic-residual-candidates.jsonl",
      "blacklistCandidateFileName": "relationship-trust-zone-semantic-blacklist-candidates.jsonl",
      "summaryFieldName": "semanticPrioritySummary",
      "canonicalWrites": false
    },
    "decisionOptionsZhTw": ["待審", "通過", "打叉", "保留待查"],
    "defaultDecisionZhTw": "待審",
    "reviewInstructionsZhTw": [
      "請先比對命題句與原文摘錄，確認原文是否真的支持這一組人物關係。",
      "只有查到外部網站或 anchor 文本的明確支持句，才可標記通過；若方向或人物錯誤，請標記打叉。",
      "打叉的關係會進入黑名單候選，之後每輪可直接阻擋相同關係鍵。",
      "找不到明確來源時請保留待查，不要用常識硬判。"
    ],
