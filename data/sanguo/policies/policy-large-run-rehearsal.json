{
  "id": "Policy_LargeRunRehearsal_P1",
  "description": "Large-run rehearsal budgets, backpressure thresholds, and mode matrix for Sanguo-RAG evidence pipeline (SANGUO-RAGOPS-0401). All decisions must be driven by telemetry + policy values, not by hardcoded source / general / cleanup strings inside runners.",
  "decisionMode": "rehearsal-only",
  "enabledByDefault": false,
  "modes": [
    {
      "id": "no-write",
      "label": "no-write dry-run",
      "writesJsonl": false,
      "writesPostgres": false,
      "writesVector": false
    },
    {
      "id": "jsonl-only",
      "label": "JSONL canonical only",
      "writesJsonl": true,
      "writesPostgres": false,
      "writesVector": false
    },
    {
      "id": "dual-write",
      "label": "JSONL + PostgreSQL mirror",
      "writesJsonl": true,
      "writesPostgres": true,
      "writesVector": false
    },
    {
      "id": "vector-smoke",
      "label": "JSONL + PostgreSQL mirror + evidence vector smoke namespace",
      "writesJsonl": true,
      "writesPostgres": true,
      "writesVector": "smoke-namespace-only"
    }
  ],
  "defaultMode": "no-write",
  "contract": {
    "requiredBudgetFields": [
      "maxRounds",
      "maxSourcesPerRound",
      "maxPagesPerSource",
      "maxRawBytesPerSource",
      "maxRawBytesPerRound",
      "maxSeedsPerRound",
      "maxCardsPerRound",
      "maxVectorRecordsPerRound",
      "maxArtifactBytesPerRun",
      "maxResumeScanSeconds",
      "maxSourceTimeoutPerRound",
      "maxTimeoutsPerRound"
    ],
    "requiredBackpressureFields": [
      "minNewEvidencePerRound",
      "minRoiPerSource",
      "consecutiveLowYieldRoundsStop"
    ],
    "requiredSignalFields": [
      "artifactBudgetExhausted",
      "roundRawBytesBudget",
      "sourceRawBytesBudget",
      "sourceTimeoutExceeded",
      "roundSeedBudget",
      "roundCardBudget",
      "roundVectorRecordBudget",
      "resumeScanBudget",
      "sourceLowRoi",
      "lowNewEvidence",
      "consecutiveLowYield",
      "timeoutSaturation"
    ],
    "requiredSourceFields": [
      "sourceId",
      "sourceFamily",
      "sourceLayer",
      "expectedFetchCount",
      "expectedHarvestedCount",
      "expectedSeedsPerRound",
      "expectedCardsPerRound",
      "expectedNewEvidence",
      "expectedTimeoutCount",
      "expectedRawBytesPerRound",
      "expectedResumeScanSeconds"
    ],
    "missingFieldBehavior": "fail-fast"
  },
  "signalIds": {
    "artifactBudgetExhausted": "artifact-budget-exhausted",
    "roundRawBytesBudget": "round-raw-bytes-budget",
    "sourceRawBytesBudget": "source-raw-bytes-budget",
    "sourceTimeoutExceeded": "source-timeout-exceeded",
    "roundSeedBudget": "round-seed-budget",
    "roundCardBudget": "round-card-budget",
    "roundVectorRecordBudget": "round-vector-record-budget",
    "resumeScanBudget": "resume-scan-budget",
    "sourceLowRoi": "source-low-roi",
    "lowNewEvidence": "low-new-evidence",
    "consecutiveLowYield": "consecutive-low-yield",
    "timeoutSaturation": "timeout-saturation"
  },
  "budgets": {
    "maxRounds": 8,
    "maxSourcesPerRound": 6,
    "maxPagesPerSource": 24,
    "maxRawBytesPerSource": 6291456,
    "maxRawBytesPerRound": 33554432,
    "maxSeedsPerRound": 800,
    "maxCardsPerRound": 240,
    "maxVectorRecordsPerRound": 200,
    "maxArtifactBytesPerRun": 209715200,
    "maxResumeScanSeconds": 12.0,
    "maxSourceTimeoutPerRound": 4,
    "maxTimeoutsPerRound": 18
  },
  "backpressure": {
    "stopWhen": {
      "roundExceedsArtifactBytes": true,
      "sourceExceedsRawBytes": true,
      "sourceTimeoutCountExceeded": true,
      "newEvidenceDeltaBelowMin": true,
      "resumeScanExceedsSeconds": true
    },
    "minNewEvidencePerRound": 5,
    "minRoiPerSource": 0.1,
    "consecutiveLowYieldRoundsStop": 2
  },
  "feedbackProposal": {
    "schemaVersion": "large-run-feedback-proposals.v0.1",
    "proposalStatus": "sandbox-proposed",
    "reviewGate": "human-review-required-before-policy-change",
    "minObservation": {
      "roundCount": 2,
      "sourceObservationCount": 2
    },
    "adjustment": {
      "headroomRatio": 0.15,
      "maxIncreaseRatio": 0.25,
      "maxDecreaseRatio": 0.15,
      "lowUtilizationRatio": 0.35,
      "minProposedValue": 1
    },
    "budgetMetricMap": {
      "maxRawBytesPerRound": "rawBytes",
      "maxSeedsPerRound": "seedCount",
      "maxCardsPerRound": "cardCount",
      "maxVectorRecordsPerRound": "vectorRecordCount",
      "maxArtifactBytesPerRun": "cumulativeArtifactBytes",
      "maxTimeoutsPerRound": "timeoutCount"
    },
    "signalToBudget": {
      "roundRawBytesBudget": {
        "budgetField": "maxRawBytesPerRound",
        "metricField": "rawBytes",
        "proposalKind": "large-run-budget-increase",
        "reason": "round raw bytes hit the configured budget"
      },
      "roundSeedBudget": {
        "budgetField": "maxSeedsPerRound",
        "metricField": "seedCount",
        "proposalKind": "large-run-budget-increase",
        "reason": "round seed count hit the configured budget"
      },
      "roundCardBudget": {
        "budgetField": "maxCardsPerRound",
        "metricField": "cardCount",
        "proposalKind": "large-run-budget-increase",
        "reason": "round card count hit the configured budget"
      },
      "roundVectorRecordBudget": {
        "budgetField": "maxVectorRecordsPerRound",
        "metricField": "vectorRecordCount",
        "proposalKind": "large-run-budget-increase",
        "reason": "round vector record count hit the configured budget"
      },
      "artifactBudgetExhausted": {
        "budgetField": "maxArtifactBytesPerRun",
        "metricField": "cumulativeArtifactBytes",
        "proposalKind": "large-run-budget-increase",
        "reason": "run artifact budget was exhausted"
      },
      "timeoutSaturation": {
        "budgetField": "maxTimeoutsPerRound",
        "metricField": "timeoutCount",
        "proposalKind": "large-run-timeout-budget-review",
        "reason": "round timeout count saturated the configured budget"
      }
    },
    "sourceSignalProposals": {
      "sourceLowRoi": {
        "proposalKind": "large-run-source-roi-review",
        "reason": "source ROI stayed below the configured minimum"
      },
      "sourceTimeoutExceeded": {
        "proposalKind": "large-run-source-timeout-review",
        "reason": "source timeout count exceeded per-source budget"
      },
      "resumeScanBudget": {
        "proposalKind": "large-run-resume-scan-review",
        "reason": "source resume scan seconds exceeded budget"
      }
    },
    "defaultBudgetDecreaseProposal": {
      "proposalKind": "large-run-budget-decrease",
      "reason": "observed utilization stayed below the configured low-utilization ratio"
    },
    "guards": [
      "proposal-only-no-policy-mutation",
      "canonicalWrites=false",
      "requires-human-review-before-apply",
      "budget-adjustment-capped-by-policy"
    ]
  },
  "telemetryFields": [
    "roundId",
    "sourceId",
    "sourceFamily",
    "sourceLayer",
    "fetchCount",
    "harvestedCount",
    "seedCount",
    "cardCount",
    "newEvidenceCount",
    "timeoutCount",
    "rawBytes",
    "artifactBytes",
    "resumeScanSeconds",
    "postgresRowCount",
    "vectorRecordCount",
    "roiScore",
    "backpressureSignal"
  ],
  "guards": [
    "no-hardcoded-general-id-in-runner",
    "no-hardcoded-source-id-in-runner",
    "no-hardcoded-cleanup-string-in-runner",
    "vector-production-namespace-disabled-by-default",
    "modes-must-be-listed-here-to-be-runnable",
    "telemetry-ledger-required-each-round"
  ]
}
