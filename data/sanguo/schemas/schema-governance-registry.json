      ],
      "requiredTopLevelFields": [
        "id"
      ],
      "idPrefixes": [
        "Rule_"
      ]
    },
    {
      "id": "SchemaEntry_GovernanceCatalogsJsonOrJsonl_P1",
      "section": "catalogs",
      "formats": [
        "json",
        "jsonl"
      ],
      "requiredTopLevelFields": [
        "id"
      ],
      "idPrefixes": [
        "Catalog_"
      ]
    },
    {
      "id": "SchemaEntry_GovernanceSchemasJson_P1",
      "section": "schemas",
      "formats": [
        "json"
      ],
      "requiredTopLevelFields": [
        "id"
      ],
      "idPrefixes": [
        "Schema_"
      ]
    }
  ],
  "registryChecks": [
